# Auto-detect text files and perform LF normalization
* text=auto

# C++ source code
*.cpp text
*.h text
*.hpp text
*.c text

# CMake and configuration files
CMakeLists.txt text
*.cmake text
*.json text

# Enforce specific line endings for scripts
*.sh text eol=lf
*.bat text eol=crlf

# Exclude binaries from diffs
*.dll binary
*.so binary
*.exe binary
*.lib binary
*.a binary
*.o binary
*.obj binary